# OpenAI API Key (GPT-4o, etc.)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# OpenRouter API Key (DeepSeek, Claude, etc.)
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY

# Run Puppeteer in headless mode (true or false)
HEADLESS=false

# Set to false to enable screenshots (opt-in)
DISABLE_SCREENSHOTS=true

# Database Connection (Required - Use SQLite path or PostgreSQL connection string)
DATABASE_URL=file:./.qaos/qaos.db

# Username/Email for the standard-login skill
TEST_USER=YOUR_TEST_USER_ACCOUNT

# Password for the standard-login skill
TEST_USER_PASSWORD=YOUR_TEST_USER_PASSWORD